struct node {
    int data;
    struct node* next;
};

typedef struct node* NODE;

NODE createNode(int x) {
    //write your code here..
    NODE newNode = (NODE)malloc(sizeof(struct node));
    newNode->data = x;
    newNode->next = NULL;

    return newNode;    
    
    
}

NODE addNode(NODE first, int x) {
    NODE newNode = createNode(x);

    // If list is empty, new node becomes the head
    if (first == NULL) {
        return newNode;
    }

    // Traverse to the last node
    NODE temp = first;
    while (temp->next != NULL) {
        temp = temp->next;
    }

    // Attach new node at the end
    temp->next = newNode;
    return first;
    
    
    
    
}

NODE concatenate(NODE t1, NODE t2) {
    if (t1 == NULL) return t2;
    if (t2 == NULL) return t1;

    // Traverse to the last node of t1
    NODE temp = t1;
    while (temp->next != NULL) {
        temp = temp->next;
    }

    // Link the last node of t1 to the head of t2
    temp->next = t2;
    return t1;
    
    
    
    
}

void displayList(NODE first) {
    //write your code here..
    if (first == NULL) {
        printf("NULL\n");
        return;
    }

    NODE temp = first;
    while (temp != NULL) {
        printf("%d", temp->data);
        if (temp->next != NULL)
            printf(" --> ");
        temp = temp->next;
    }
    printf(" --> NULL\n");
    
    
    
}
